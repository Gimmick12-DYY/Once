# Perplexity API key (https://www.perplexity.ai/settings/api)
PERPLEXITY_API_KEY=

# Anthropic API key for PDF summarize mode (`-summarize`)
ANTHROPIC_API_KEY=

# Optional: default Obsidian vault name (if you have multiple vaults)
# OBSIDIAN_VAULT=MyVault

# Optional: default output folder for auto file writing (no -out needed).
# If set, `npm run once -- -research "..."` writes here by default.
# ONCE_DEFAULT_OUT_DIR=/Users/dyy/Library/CloudStorage/OneDrive-UniversityofNorthCarolinaatChapelHill/Gimmicks/Import

# Optional: source folder for PDF summarize mode.
# If unset, defaults to sibling `need` folder next to ONCE_DEFAULT_OUT_DIR.
# ONCE_NEED_DIR=/Users/dyy/Library/CloudStorage/OneDrive-UniversityofNorthCarolinaatChapelHill/Gimmicks/need
